# ─── Vercel Postgres ──────────────────────────────────────────────────────────
# From: Vercel dashboard → Storage → Postgres → .env.local tab
# Or use any Postgres connection string (Neon, Supabase, local)
POSTGRES_URL="postgres://user:password@host/database?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/database?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (magic link) ───────────────────────────────────────────────────────
# Resend (recommended): smtp://resend:YOUR_API_KEY@smtp.resend.com:587
# Gmail: smtp://you%40gmail.com:app-password@smtp.gmail.com:587
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="IRON <noreply@ironmap.cz>"

# ─── Google Places API (enrichment scripts only, never exposed to client) ──────
GOOGLE_PLACES_API_KEY="your-places-api-key"

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="iron-photos"
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
